            "enabled": true,
            "id": "faq",
            "title": "Frequently asked questions",
            "subtitle": "The essentials before you book your invitation.",
            "footerCtaTitle": "Ready for the invitation you’ll love sharing?",
            "items": [
                {
                    "question": "What’s the step-by-step process after I choose a plan?",
                    "answer": "You complete the booking form, send your summary, and pay a 50% deposit. Then we align details with you on WhatsApp, design your invitation, and deliver the final link."
                },
                {
                    "question": "What is included in Premium, and what can I add as extras?",
                    "answer": "Premium includes 5 sections, up to 5 photos, custom colors/phrases, and WhatsApp confirmations. You can add extras like the dashboard, a second language, or additional sections."
                },
                {
                    "question": "What’s the difference between RSVP confirmations by WhatsApp and using the Dashboard?",
                    "answer": "With WhatsApp, confirmations arrive as messages. That’s often enough, but if you have many guests or want to avoid tracking responses manually, we recommend the Dashboard. It keeps everything organized in real time (attending, pending, not attending, and dietary needs)."
                },
                {
                    "question": "Can I make changes after sending the booking form?",
                    "answer": "Yes. Before final delivery, we coordinate content and visual finish adjustments."
                },
                {
                    "question": "How long does delivery take?",
                    "answer": "The usual timeline is {{deliveryRangeEn}}. If you need it urgently, you can add 24-hour rush delivery."
                },
                {
                    "question": "How does payment work?",
                    "answer": "You book with a 50% deposit, and the remaining 50% is paid when your final invitation is delivered."
                },
                {
                    "question": "How is the invitation shared, and how long does it stay active?",
                    "answer": "We deliver a unique link you can share via WhatsApp, social media, or email (no app needed). The link stays active for up to 3 months after the event."
                }
            ]
        }
