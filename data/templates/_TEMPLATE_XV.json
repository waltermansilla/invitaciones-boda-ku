        "qrUrl": "",
        "qrStyle": {
            "fgColor": "#3D3D3D",
            "bgColor": "transparent"
        },
        "cardStyle": {
            "bgColor": "#FDF8F3",
            "textColor": "#4A4A4A",
            "accentColor": "#D4A5A5"
        },
        "brand": {
            "type": "instagram",
            "text": "Momento Unico Invitaciones",
            "logoUrl": "",
            "instagramHandle": "@momentounico_invitaciones"
        }
