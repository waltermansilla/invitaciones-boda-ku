{
    "// ==========================================================================": "",
    "// TEMPLATE XV - GUIA COMPLETA                                               ": "",
    "// ==========================================================================": "",
    "//                                                                            ": "",
    "// Este archivo es SOLO DE REFERENCIA. No se usa en la app.                  ": "",
    "// Para crear un XV: copiar a data/clientes/xv/[slug].json                   ": "",
    "//                                                                            ": "",
    "// MIGRACION DE IMAGENES A BLOB:                                             ": "",
    "// 1. Trabaja con imagenes locales en public/clientes/xv/[slug]/             ": "",
    "// 2. Cuando esten listas, ejecuta: npx tsx scripts/migrate-to-blob.ts       ": "",
    "// 3. El script sube las imagenes y actualiza los JSONs automaticamente      ": "",
    "// ==========================================================================": "",

    "// ==========================================================================": "",
    "// META - Informacion basica de la invitacion                                ": "",
    "// ==========================================================================": "",
    "// title: titulo de la pagina (SEO)                                          ": "",
    "// description: descripcion para redes sociales                              ": "",
    "// quinceaneraName: nombre de la quinceanera                                 ": "",
    "// coupleNames: se usa internamente (brideName = nombre de la quinceanera)   ": "",
    "// ==========================================================================": "",

    "meta": {
        "title": "XV de Nombre",
        "description": "Te invitamos a celebrar mis 15.",
        "lang": "es",
        "quinceaneraName": "Nombre de la quinceanera",
        "coupleNames": {
            "groomName": "",
            "brideName": "Nombre de la quinceanera",
            "separator": ""
        }
    },

    "// ==========================================================================": "",
    "// ACCESS - Token de acceso para la invitacion real                          ": "",
    "// ==========================================================================": "",
    "// OPCION FACIL (recomendada para operar rapido):                            ": "",
    "//   - usar SOLO token corto (6 chars) en access.token                       ": "",
    "//                                                                            ": "",
    "// OPCION MAS SEGURA:                                                        ": "",
    "//   - guardar access.tokenHash (SHA-256) y evitar token plano en repo       ": "",
    "//   - generar con: node scripts/gen-access-token.mjs                        ": "",
    "//                                                                            ": "",
    "// tokenEnabled: true exige ?t=TOKEN en /tipo/slug                           ": "",
    "// token: token real de 6 chars (A-Z a-z 0-9). Puede usarse sin hash.        ": "",
    "// tokenHash: SHA-256 (hex) del token real de 6 caracteres (opcional)        ": "",
    "// allowLegacyUntil (opcional): fecha YYYY-MM-DD para permitir sin token     ": "",
    "// ==========================================================================": "",
    "access": {
        "tokenEnabled": false,
        "token": "",
        "tokenHash": "",
        "allowLegacyUntil": ""
    },

    "// ==========================================================================": "",
    "// RSVP PANEL - Panel de confirmaciones (opcional)                          ": "",
    "// ==========================================================================": "",
    "// enabled: true = activa integracion con panel (Supabase)                  ": "",
    "// panelId: id unico del panel (URL: /panel/[panelId])                      ": "",
    "// fechaEvento: YYYY-MM-DD (para contador interno del panel)                ": "",
    "// confirmationMessage: mensaje post-confirmacion al invitado               ": "",
    "// confirmacion:                                                             ": "",
    "//   - 'formulario' = usa seccion 'rsvp' + API panel                        ": "",
    "//   - 'comun' = usa seccion 'confirmarWhatsapp' + registra en panel        ": "",
    "//              antes de abrir WhatsApp (solo invitados individuales)       ": "",
    "// limiteInvitados (opcional): tope de plazas del panel                     ": "",
    "//   - persona = 1 plaza                                                     ": "",
    "//   - familia = cantidad de integrantes (minimo 1)                         ": "",
    "// registrarSinCodigoEnPanel (solo confirmacion='formulario'):              ": "",
    "//   - true  = si entran sin ?i= y envian RSVP, crea invitado en panel      ": "",
    "//             y registra confirmacion                                       ": "",
    "//   - false = sin ?i= el RSVP solo envia WhatsApp (no impacta panel)       ": "",
    "// theme/labels: colores y textos del panel                                 ": "",
    "// ==========================================================================": "",
    "rsvpPanel": {
        "enabled": false,
        "confirmacion": "formulario",
        "registrarSinCodigoEnPanel": false,
        "panelId": "nombre-xv-demo",
        "// legacyPanelIds: al cambiar panelId, poner aca el id viejo hasta el 1er GET del panel (luego vaciar)": "",
        "legacyPanelIds": [],
        "fechaEvento": "2027-02-17",
        "confirmationMessage": "Gracias por confirmar! Te esperamos en los XV.",
        "limiteInvitados": 120,
        "theme": {
            "primaryColor": "#C4788A"
        },
        "labels": {
            "title": "Panel de Invitados",
            "totalLabel": "Total invitados",
            "confirmedLabel": "Confirmados",
            "pendingLabel": "Pendientes",
            "declinedLabel": "No asisten",
            "paymentPending": "Pago pendiente",
            "addGuest": "Agregar Invitado",
            "copyLink": "Copiar link",
            "manualConfirm": "Confirmación manual",
            "paidButton": "Ya pagó",
            "unpaidButton": "¿Pagó tarjeta?"
        }
    },

    "// ==========================================================================": "",
    "// THEME - Colores y tipografia                                              ": "",
    "// ==========================================================================": "",
    "// primaryColor: color principal (botones, fondos destacados)                ": "",
    "// backgroundColor: fondo general claro                                      ": "",
    "// backgroundImage: imagen de fondo alternativa (opcional)                   ": "",
    "// primaryImage: imagen para secciones con fondo primary (opcional)          ": "",
    "// textColor: color de texto general                                         ": "",
    "// lightBgTextColor: texto sobre fondo claro                                 ": "",
    "// darkBgTextColor: texto sobre fondo oscuro                                 ": "",
    "// font.family: fuente de Google Fonts                                       ": "",
    "// font.weights: pesos a cargar (separados por coma)                         ": "",
    "// ==========================================================================": "",

    "theme": {
        "primaryColor": "#C4788A",
        "backgroundColor": "#FFF9F7",
        "backgroundImage": "",
        "primaryImage": "",
        "textColor": "#3A3A3A",
        "lightBgTextColor": "#C4788A",
        "darkBgTextColor": "#FFFFFF",
        "accentBackground": "#FDF0EE",
        "modalTextColor": "#FFFFFF",
        "font": {
            "family": "Josefin Sans",
            "weights": "100,200,300,400,500,600,700"
        }
    },

    "// ==========================================================================": "",
    "// OVERLAY - Pantalla de bienvenida                                          ": "",
    "// ==========================================================================": "",
    "// enabled: true/false                                                       ": "",
    "// phrase: frase de bienvenida (ej: 'Mis 15!')                               ": "",
    "// buttonText: texto del boton de entrada                                    ": "",
    "// bgColor: color de fondo personalizado (hex) o vacio para usar theme       ": "",
    "// bgImage: imagen de fondo (ruta o vacio)                                   ": "",
    "// showNames: true/false                                                     ": "",
    "// showPhrase: true/false                                                    ": "",
    "// buttonPosition: 'center', 'top', 'bottom', o numero 0-100                 ": "",
    "// textPositionsPx (opcional): posicion vertical individual en pixeles        ": "",
    "//   Formato por campo:                                                      ": "",
    "//   - solo Y: 310                                                           ": "",
    "//   - Y y X en la misma propiedad: '310, 50' (Y primero, X despues)        ": "",
    "//   brideY: nombre principal                                                 ": "",
    "//   separatorY: separador '&' (si aplica)                                    ": "",
    "//   groomY: segundo nombre (si aplica)                                       ": "",
    "//   phraseY: frase                                                           ": "",
    "//   topLineY: linea decorativa superior (opcional)                          ": "",
    "//   bottomLineY: linea decorativa inferior (opcional)                       ": "",
    "//   buttonY: boton en px (opcional, tiene prioridad sobre buttonPosition)   ": "",
    "//   Si NO pones topLineY/bottomLineY, las lineas no se muestran en modo px  ": "",
    "//   IMPORTANTE: si usas textPositionsPx, ajusta cada valor para tu imagen    ": "",
    "// nameStyle: ver documentacion en template BODA                             ": "",
    "// ==========================================================================": "",

    "overlay": {
        "enabled": true,
        "phrase": "Mis 15!",
        "buttonText": "Abrir invitacion",
        "bgColor": "",
        "bgImage": "",
        "showNames": true,
        "showPhrase": true,
        "nameStyle": {
            "font": "",
            "size": "4xl",
            "weight": "200",
            "color": "",
            "lowercase": false,
            "letterSpacing": "wide"
        },
        "buttonPosition": "center",
        "textPositionsPx": {
            "topLineY": 130,
            "brideY": 170,
            "separatorY": 260,
            "groomY": 310,
            "phraseY": 430,
            "bottomLineY": 380,
            "buttonY": 560
        }
    },

    "// ==========================================================================": "",
    "// MUSIC - Musica de fondo                                                   ": "",
    "// ==========================================================================": "",
    "// enabled: true/false                                                       ": "",
    "// src: ruta al archivo mp3                                                  ": "",
    "// autoplay: true = inicia al tocar 'Ingresar', false = manual               ": "",
    "// startTime: segundos desde donde empieza (0 = inicio)                      ": "",
    "// endTime: segundos donde termina/corta la musica (0 = sin corte)           ": "",
    "// Se puede usar solo startTime, solo endTime, o ambos                        ": "",
    "// ==========================================================================": "",

    "music": {
        "enabled": true,
        "src": "/music/background.mp3",
        "autoplay": false,
        "startTime": 0,
        "endTime": 0
    },

    "// ==========================================================================": "",
    "// QR CARD - Tarjeta imprimible con QR                                       ": "",
    "// ==========================================================================": "",
    "// Accede en: /xv/{slug}/qr (misma regla que otros tipos)                    ": "",
    "//                                                                            ": "",
    "// enabled: true/false (false = pagina 404)                                  ": "",
    "// names: text1 (titulo chico), text2 (nombre grande)                        ": "",
    "// icon: 'camera','sparkles','crown','star','heart','none'                   ": "",
    "// title/description: textos de la tarjeta                                   ": "",
    "// qrUrl: URL del QR (vacio = usa URL de la invitacion)                      ": "",
    "// qrStyle: fgColor (color QR), bgColor (fondo QR)                           ": "",
    "// cardStyle: bgColor, textColor, accentColor                                ": "",
    "// brand.type: 'instagram', 'text', 'logo', 'none'                           ": "",
    "// ==========================================================================": "",

    "qrCard": {
        "enabled": true,
        "names": {
            "text1": "Mis XV",
