{
    "// ==========================================================================": "",
    "// TEMPLATE XV - GUIA COMPLETA                                               ": "",
    "// ==========================================================================": "",
    "//                                                                            ": "",
    "// Este archivo es SOLO DE REFERENCIA. No se usa en la app.                  ": "",
    "// Para crear un XV: copiar a data/clientes/xv/[slug].json                   ": "",
    "//                                                                            ": "",
    "// MIGRACION DE IMAGENES A BLOB:                                             ": "",
    "// 1. Trabaja con imagenes locales en public/clientes/xv/[slug]/             ": "",
    "// 2. Cuando esten listas, ejecuta: npx tsx scripts/migrate-to-blob.ts       ": "",
    "// 3. El script sube las imagenes y actualiza los JSONs automaticamente      ": "",
    "// ==========================================================================": "",



    "// ==========================================================================": "",
    "// META - Informacion basica de la invitacion                                ": "",
    "// ==========================================================================": "",
    "// title: titulo de la pagina (SEO)                                          ": "",
    "// description: descripcion para redes sociales                              ": "",
    "// quinceaneraName: nombre de la quinceanera                                 ": "",
    "// coupleNames: se usa internamente (brideName = nombre de la quinceanera)   ": "",
    "// ==========================================================================": "",

    "meta": {
        "title": "XV de Nombre",
        "description": "Te invitamos a celebrar mis 15.",
        "lang": "es",
        "quinceaneraName": "Nombre de la quinceanera",
        "coupleNames": {
            "groomName": "",
            "brideName": "Nombre de la quinceanera",
            "separator": ""
        }
    },



    "// ==========================================================================": "",
    "// THEME - Colores y tipografia                                              ": "",
    "// ==========================================================================": "",
    "// primaryColor: color principal (botones, fondos destacados)                ": "",
    "// backgroundColor: fondo general claro                                      ": "",
    "// backgroundImage: imagen de fondo alternativa (opcional)                   ": "",
    "// primaryImage: imagen para secciones con fondo primary (opcional)          ": "",
    "// textColor: color de texto general                                         ": "",
    "// lightBgTextColor: texto sobre fondo claro                                 ": "",
    "// darkBgTextColor: texto sobre fondo oscuro                                 ": "",
    "// font.family: fuente de Google Fonts                                       ": "",
    "// font.weights: pesos a cargar (separados por coma)                         ": "",
    "// ==========================================================================": "",

    "theme": {
        "primaryColor": "#C4788A",
        "backgroundColor": "#FFF9F7",
        "backgroundImage": "",
        "primaryImage": "",
        "textColor": "#3A3A3A",
        "lightBgTextColor": "#C4788A",
        "darkBgTextColor": "#FFFFFF",
        "accentBackground": "#FDF0EE",
        "modalTextColor": "#FFFFFF",
        "font": {
            "family": "Josefin Sans",
            "weights": "100,200,300,400,500,600,700"
        }
    },



    "// ==========================================================================": "",
    "// OVERLAY - Pantalla de bienvenida                                          ": "",
    "// ==========================================================================": "",
    "// enabled: true/false                                                       ": "",
    "// phrase: frase de bienvenida (ej: 'Mis 15!')                               ": "",
    "// buttonText: texto del boton de entrada                                    ": "",
    "// bgColor: color de fondo personalizado (hex) o vacio para usar theme       ": "",
    "// bgImage: imagen de fondo (ruta o vacio)                                   ": "",
    "// showNames: true/false                                                     ": "",
    "// showPhrase: true/false                                                    ": "",
    "// buttonPosition: 'center', 'top', 'bottom', o numero 0-100                 ": "",
    "// nameStyle: ver documentacion en template BODA                             ": "",
    "// ==========================================================================": "",

    "overlay": {
        "enabled": true,
        "phrase": "Mis 15!",
        "buttonText": "Abrir invitacion",
        "bgColor": "",
        "bgImage": "",
        "showNames": true,
        "showPhrase": true,
        "nameStyle": {
            "font": "",
            "size": "4xl",
            "weight": "200",
            "color": "",
            "lowercase": false,
            "letterSpacing": "wide"
        },
        "buttonPosition": "center"
    },



    "// ==========================================================================": "",
    "// MUSIC - Musica de fondo                                                   ": "",
    "// ==========================================================================": "",
    "// enabled: true/false                                                       ": "",
    "// src: ruta al archivo mp3                                                  ": "",
    "// autoplay: true = inicia al tocar 'Ingresar', false = manual               ": "",
    "// startTime: segundos desde donde empieza (0 = inicio)                      ": "",
    "// ==========================================================================": "",

    "music": {
        "enabled": true,
        "src": "/music/background.mp3",
        "autoplay": false,
        "startTime": 0
    },



    "// ==========================================================================": "",
    "// QR CARD - Tarjeta imprimible con QR                                       ": "",
    "// ==========================================================================": "",
    "// Accede en: /xv/[slug]/qr                                                  ": "",
    "//                                                                            ": "",
    "// enabled: true/false (false = pagina 404)                                  ": "",
    "// names: text1 (titulo chico), text2 (nombre grande)                        ": "",
    "// icon: 'camera','sparkles','crown','star','heart','none'                   ": "",
    "// title/description: textos de la tarjeta                                   ": "",
    "// qrUrl: URL del QR (vacio = usa URL de la invitacion)                      ": "",
    "// qrStyle: fgColor (color QR), bgColor (fondo QR)                           ": "",
    "// cardStyle: bgColor, textColor, accentColor                                ": "",
    "// brand.type: 'instagram', 'text', 'logo', 'none'                           ": "",
    "// ==========================================================================": "",

    "qrCard": {
        "enabled": true,
        "names": {
            "text1": "Mis XV",
            "text2": "Valentina"
        },
        "icon": "camera",
        "title": "Comparti tus fotos",
        "description": "Subi tus fotos de la fiesta y ayudame a guardar los recuerdos de este dia tan especial",
        "qrUrl": "",
        "qrStyle": {
            "fgColor": "#3D3D3D",
            "bgColor": "transparent"
        },
        "cardStyle": {
            "bgColor": "#FDF8F3",
            "textColor": "#4A4A4A",
            "accentColor": "#D4A5A5"
        },
        "brand": {
            "type": "instagram",
            "text": "Momento Unico Invitaciones",
            "logoUrl": "",
            "instagramHandle": "@momentounico_invitaciones"
        }
    },



    "// ==========================================================================": "",
    "// HERO - Seccion principal con foto y countdown                             ": "",
    "// ==========================================================================": "",
    "// Ver documentacion completa en template BODA                               ": "",
    "// La estructura es identica                                                 ": "",
    "// ==========================================================================": "",

    "hero": {
        "coupleImage": "/clientes/xv/[slug]/hero.jpg",
        "headline": "Mis 15!",
        "showNamesOnPhoto": true,
        "namesDisplay": {
            "enabled": true,
            "position": "bottom",
            "positionX": null,
            "positionY": null,
            "color": "rgba(255,255,255,0.9)",
            "decorativeLines": false,
            "logo": "",
            "texts": [
                { "text": "Mis XV", "font": "", "weight": "200", "size": "base", "style": "normal", "letterSpacing": "wide" },
                { "text": "Valentina", "font": "", "weight": "300", "size": "2xl", "style": "normal", "letterSpacing": "none" }
            ],
            "font": "",
            "weight": "300",
            "size": "lg",
            "style": "normal",
            "lowercase": false,
            "letterSpacing": "wide"
        },
        "countdownPrefix": "Faltan",
        "eventDate": "2027-01-01T21:00:00",
        "countdownLabels": {
            "days": "Dias",
            "hours": "Horas",
            "minutes": "Minutos",
            "seconds": "Segundos"
        },
        "countdownAreaBg": "background",
        "countdownStyle": {
            "background": "none",
            "shape": "rounded",
            "layout": "inline",
            "overlayStyle": "card"
        }
    },



    "// ==========================================================================": "",
    "// SECTIONS - Secciones de contenido                                         ": "",
    "// ==========================================================================": "",
    "// El ORDEN en el array define el orden visual en la pagina.                 ": "",
    "// Ver documentacion completa de cada tipo en template BODA.                 ": "",
    "//                                                                            ": "",
    "// TIPOS EXCLUSIVOS DE XV:                                                    ": "",
    "//   presentation: foto + nombre + descripcion                               ": "",
    "//   parents: nombre de los padres                                           ": "",
    "// ==========================================================================": "",

    "sections": [



        {
            "// ----------------------------------------------------------------------": "",
            "// QUOTE - Frase de bienvenida                                           ": "",
            "// ----------------------------------------------------------------------": "",
            "type": "quote",
            "id": "quote-welcome",
            "enabled": true,
            "bgColor": "primary",
            "data": {
                "text": "La vida es una fiesta, y hoy quiero celebrarla con vos.",
                "author": "",
                "decorativeLines": true
            }
        },



        {
            "// ----------------------------------------------------------------------": "",
            "// PRESENTATION - Foto y presentacion (EXCLUSIVO XV)                     ": "",
            "// ----------------------------------------------------------------------": "",
            "// image: foto de la quinceanera                                         ": "",
            "// name: nombre                                                          ": "",
            "// description: texto de presentacion                                    ": "",
            "// aspectRatio: proporcion de la foto                                    ": "",
            "// ----------------------------------------------------------------------": "",
            "type": "presentation",
            "id": "presentation",
            "enabled": true,
            "data": {
                "image": "/clientes/xv/[slug]/portrait.jpg",
