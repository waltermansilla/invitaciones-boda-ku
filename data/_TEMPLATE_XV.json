{
    "// ==========================================": "",
    "// TEMPLATE XV - TODAS LAS SECCIONES         ": "",
    "// ==========================================.": "",
    "//": "",
    "// NO se usa en la app. Solo de referencia.",
    "// Para crear un nuevo XV: copiar a data/clientes/xv/[slug].json",
    "// y borrar/editar lo que no necesites.",

    "meta": {
        "title": "XV de Nombre",
        "description": "Te invitamos a celebrar mis 15.",
        "lang": "es",
        "quinceaneraName": "Nombre de la quinceanera",
        "coupleNames": {
            "groomName": "",
            "brideName": "Nombre de la quinceanera",
            "separator": ""
        }
    },

    "theme": {
        "primaryColor": "#C4788A",
        "backgroundColor": "#FFF9F7",
        "textColor": "#3A3A3A",
        "lightBgTextColor": "#C4788A",
        "darkBgTextColor": "#FFFFFF",
        "accentBackground": "#FDF0EE",
        "modalTextColor": "#FFFFFF",
        "font": {
            "family": "Josefin Sans",
            "weights": "100,200,300,400,500,600,700"
        }
    },

    "overlay": {
        "enabled": true,
        "phrase": "Mis 15!",
        "buttonText": "Abrir invitacion"
    },

    "music": {
        "enabled": true,
        "src": "/music/background.mp3",
        "autoplay": false
    },

    "_comment_qrCard": "TARJETA QR IMPRIMIBLE - Accede en /xv/[slug]/qr. Para compartir fotos de la fiesta.",
    "qrCard": {
        "names": {
            "text1": "Mis XV",
            "text2": "Valentina",
            "_comment": "text1 es el titulo chico (ej: Mis XV), text2 es el nombre grande",
            "font1": "'Cormorant Garamond', serif",
            "font2": "'Great Vibes', cursive"
        },
        "icon": "sparkles",
        "_comment_icon": "Icono: 'sparkles', 'camera', 'crown', 'star', 'heart', 'none'",
        "title": "Comparti tus fotos",
        "description": "Subi tus fotos de la fiesta y ayudame a guardar los recuerdos de este dia tan especial",
        "qrUrl": "",
        "_comment_qrUrl": "URL del QR. Dejar vacio para usar la URL de la invitacion.",
        "qrStyle": {
            "fgColor": "#3D3D3D",
            "bgColor": "transparent",
            "cornerStyle": "rounded"
        },
        "cardStyle": {
            "bgColor": "#FDF8F3",
            "textColor": "#3D3D3D",
            "accentColor": "#D4A5A5",
            "_comment": "accentColor para estrellas y decoraciones. Por defecto toma primaryColor."
        },
        "brand": {
            "type": "instagram",
            "_comment_type": "'instagram', 'text', 'logo', 'none'",
            "text": "Momento Unico Invitaciones",
            "logoUrl": "",
            "instagramHandle": "@momentounico_invitaciones"
        }
    },

    "hero": {
        "coupleImage": "/clientes/xv/[slug]/hero.jpg",
        "headline": "Mis 15!",
        "showNamesOnPhoto": true,

        "_comment_namesDisplay": "NOMBRES EN LA FOTO. enabled: true/false. position: 'top'/'bottom'. color: hex (compartido). decorativeLines: lineas decorativas. logo: ruta imagen. TEXTOS SEPARADOS: usar 'texts' array con 2 items (ej: 'Mis XV' y 'Valentina'), cada uno con text/font/weight/size/style propios.",
        "namesDisplay": {
            "enabled": true,
            "position": "bottom",
            "color": "rgba(255,255,255,0.9)",
            "decorativeLines": false,
            "logo": "",
            "_comment_texts": "OPCIONAL: Para 2 textos con estilos distintos (ej: 'Mis XV' en una fuente y 'Valentina' en otra).",
            "texts": [
                { "text": "Mis XV", "font": "", "weight": "200", "size": "base", "style": "normal" },
                { "text": "Valentina", "font": "", "weight": "300", "size": "2xl", "style": "normal" }
            ],
            "_comment_legacy": "Si no usas 'texts', estos valores se aplican:",
            "font": "",
            "weight": "300",
            "size": "lg",
            "style": "normal"
        },

        "countdownPrefix": "Faltan",
        "eventDate": "2027-01-01T21:00:00",
        "countdownLabels": {
            "days": "Dias",
            "hours": "Horas",
            "minutes": "Minutos",
            "seconds": "Segundos"
        },

        "_comment_countdownAreaBg": "FONDO DEL AREA DEL COUNTDOWN. Opciones: 'background', 'primary', o un hex.",
        "countdownAreaBg": "background",

        "_comment_countdownStyle": "ESTILO DE CADA NUMERO. background: 'none'/'background'/'primary'/'secondary' o hex. shape: 'rounded'/'circle'/'square'/'pill'. layout: 'inline' (normal) o 'overlay' (superpuesto). overlayStyle: 'card' (con caja + Faltan) o 'floating' (items sueltos sin caja ni Faltan).",
        "countdownStyle": {
            "background": "none",
            "shape": "rounded",
            "layout": "inline",
            "overlayStyle": "card"
        }
    },

    "_comment_sections": "El orden de los objetos define el orden visual en la pagina. enabled: true/false para activar/desactivar cada seccion (true por defecto). bgColor: 'primary' = fondo color principal, 'background' = fondo claro (default si no se pone).",

    "sections": [

        {
            "_comment": "QUOTE: Frase de bienvenida. decorativeLines: true/false para lineas arriba y abajo.",
            "type": "quote",
            "id": "quote-welcome",
            "enabled": true,
            "bgColor": "primary",
            "blocks": ["text", "author"],
            "data": {
                "text": "La vida es una fiesta, y hoy quiero celebrarla con vos.",
                "author": "",
                "decorativeLines": true
            }
        },

        {
            "_comment": "PRESENTATION: Foto + nombre + descripcion. EXCLUSIVO DE XV.",
            "type": "presentation",
            "id": "presentation",
            "enabled": true,
            "blocks": ["image", "name", "description"],
            "data": {
                "image": "/clientes/xv/[slug]/portrait.jpg",
                "name": "Nombre",
                "description": "Texto de presentacion personal.",
                "aspectRatio": "3/4"
            }
        },

        {
            "_comment": "PARENTS: Nombre de los padres/padrinos. EXCLUSIVO DE XV.",
            "type": "parents",
            "id": "parents",
            "enabled": true,
            "bgColor": "primary",
            "blocks": ["title", "parents"],
            "data": {
                "title": "Mis Padres",
                "subtitle": "Con mucho amor me acompanan en este dia tan especial",
                "parents": [
                    { "name": "Nombre Mama", "role": "Mama" },
                    { "name": "Nombre Papa", "role": "Papa" }
                ]
            }
        },

        {
            "_comment": "OUR STORY: Momentos de crecimiento. Adaptado como 'Mi historia'.",
            "type": "ourStory",
            "id": "my-story",
            "enabled": true,
            "bgColor": "background",
            "blocks": ["title", "moments"],
            "data": {
                "aspectRatio": "3/4",
                "title": "Mi historia",
                "moments": [
                    { "image": "/clientes/xv/[slug]/momento-1.jpg", "title": "Mis primeros pasos", "text": "Descripcion." },
                    { "image": "/clientes/xv/[slug]/momento-2.jpg", "title": "Creciendo", "text": "Descripcion." },
                    { "image": "/clientes/xv/[slug]/momento-3.jpg", "title": "Hoy, mis 15", "text": "Descripcion." }
                ]
            }
        },

        {
            "_comment": "DATE INFO: Fecha del evento.",
            "type": "dateInfo",
            "id": "date-info",
            "enabled": true,
            "bgColor": "background",
            "blocks": ["title", "value"],
            "data": { "title": "Cuando?", "value": "17 de Febrero 2027" }
        },

        {
            "_comment": "LOCATION INFO: Ubicacion con boton de mapa. ICONOS: 'pin' (default), 'church', 'dinner', 'party', 'salon', 'book', 'podium', 'reception', 'ring', 'music', 'sparkles'. showButton: true/false. datetime: fecha y hora opcional.",
            "type": "locationInfo",
            "id": "location-fiesta",
            "enabled": true,
            "bgColor": "background",
            "blocks": ["title", "address", "button"],
            "data": {
                "icon": "party",
                "title": "Salon de fiesta",
                "address": "Direccion completa del salon",
                "showButton": true,
                "datetime": {
                    "date": "Sabado 17 de Febrero",
                    "time": "21:00 hs"
                },
                "button": { "text": "Como llegar", "url": "https://maps.google.com", "variant": "primary" }
            }
        },

        {
            "_comment": "GALLERY: Slider de fotos.",
            "type": "gallery",
            "id": "gallery-photos",
            "enabled": true,
            "blocks": ["slider"],
            "data": {
                "aspectRatio": "3/4",
                "images": [
                    "/clientes/xv/[slug]/galeria-1.jpg",
                    "/clientes/xv/[slug]/galeria-2.jpg",
                    "/clientes/xv/[slug]/galeria-3.jpg"
                ]
            }
        },

        {
            "_comment": "ITINERARY: Linea de tiempo. Cada evento puede tener: icon, name, address (direccion arriba de la hora), time, date (opcional), button (opcional). ICONOS: heart, wine, utensils, music, church, camera, cake, car, glass, party, sparkles, sun, moon, clock, pin, gift, bus, podium, book, salon, civil, mate, fin, sidra, mesaDulce, tortaCasamiento.",
            "type": "itinerary",
            "id": "itinerary-timeline",
            "enabled": true,
            "bgColor": "background",
            "blocks": ["title", "timeline"],
            "data": {
                "title": "Itinerario",
                "events": [
                    { "icon": "sparkles", "name": "Recepcion", "address": "Salon de Eventos - Ruta 14 Km 5", "time": "20:00 hs" },
                    { "icon": "utensils", "name": "Cena", "time": "21:00 hs" },
                    { "icon": "heart", "name": "Vals con papa", "time": "22:00 hs" },
                    { "icon": "cake", "name": "Torta", "time": "23:00 hs" },
                    { "icon": "music", "name": "Fiesta", "time": "00:00 hs" },
                    { "icon": "fin", "name": "Fin de fiesta", "time": "05:00 hs" }
                ]
            }
        },

        {
            "_comment": "DRESS CODE: Vestimenta con iconos, colores y modal. ICONOS: dress, suit, gem, crown, sparkles, star, heart. showButton: true/false. colorSwatches: enabled, shape ('circle'/'square'), colors (array hex).",
            "type": "dressCode",
            "id": "dress-code",
            "enabled": true,
            "bgColor": "background",
            "blocks": ["title", "subtitle", "icons", "description", "colorSwatches", "button", "modal"],
            "data": {
                "icons": ["dress", "suit", "gem"],
                "title": "Vestimenta",
                "subtitle": "Elegante",
                "description": "",
                "showButton": true,
                "colorSwatches": {
                    "enabled": false,
                    "shape": "circle",
                    "colors": []
                },
                "button": { "text": "Ver consejos", "url": "#", "variant": "secondary" },
                "modal": {
                    "title": "Consejos de vestimenta",
                    "sections": [
                        { "heading": "Chicas", "text": "Descripcion." },
                        { "heading": "Chicos", "text": "Descripcion." },
                        { "heading": "General", "text": "Descripcion." }
                    ]
                }
            }
        },

        {
            "_comment": "PHOTOS: Invitar a subir fotos. ICONOS: 'camera' (camara), 'flash' (flash), 'images' (fotos). Dejar vacio para sin icono.",
            "type": "photos",
            "id": "shared-photos",
            "enabled": true,
            "bgColor": "primary",
            "blocks": ["icon", "title", "description", "button"],
            "data": {
                "icon": "camera",
                "title": "Subi tus fotos",
                "description": "Comparti los momentos de la fiesta!",
                "button": { "text": "Ir al album", "url": "https://photos.google.com", "variant": "background" }
            }
        },

        {
            "_comment": "TRUTHS: Juego A o B.",
            "type": "truths",
            "id": "truths-game",
            "enabled": true,
            "bgColor": "primary",
            "blocks": ["title", "questions"],
            "data": {
                "title": "Cuanto me conoces?",
                "finishText": "Me conoces mejor de lo que pensaba!",
                "questions": [
                    { "question": "Que prefiero?", "optionA": "Playa", "optionB": "Montana", "correctOption": "A", "revealText": "Soy de playa total!" }
                ]
            }
        },

        {
            "_comment": "GIFT CARD: Tarjeta de regalo con modal. ICONOS: gift (caja regalo), creditCard (tarjeta), heart (corazon), star (estrella), sparkles (brillos), handHeart (mano corazon), dollar (signo pesos). suggestedValue = valor sugerido (dejar '' si no queres mostrar).",
            "type": "giftCard",
            "id": "gift-card",
            "enabled": true,
            "bgColor": "primary",
            "blocks": ["icon", "title", "description", "button", "modal"],
            "data": {
                "icon": "gift",
                "title": "Valor Tarjeta",
                "description": "Si queres hacerme un regalo, podes contribuir con un valor para mi fiesta.",
                "button": { "text": "Ver datos", "url": "#", "variant": "secondary" },
                "modal": {
                    "title": "Datos de transferencia",
                    "suggestedValueLabel": "Valor tarjeta por persona",
                    "suggestedValue": "$15.000",
                    "description": "Podes transferir el monto que quieras.",
                    "transferData": [
                        { "label": "Alias", "value": "MI.ALIAS" },
                        { "label": "CBU", "value": "0000000000000000000000" },
                        { "label": "Titular", "value": "Nombre del padre/madre" },
                        { "label": "Banco", "value": "Nombre del Banco" }
                    ]
                }
            }
        },

        {
            "_comment": "HONEYMOON: Regalos. OPCIONES: button.action = 'modal' (abre modal) o 'url' (abre link). MODALES MULTIPLES: usar 'modals' (array), type: 'bank' o 'address'. modalMode: 'combined' o 'sequential'.",
            "type": "honeymoon",
            "id": "dream-trip",
            "enabled": true,
            "bgColor": "primary",
            "blocks": ["icon", "title", "description", "button", "modals"],
            "data": {
                "icon": "gift",
                "title": "Regalos",
                "description": "Tu presencia es el mejor regalo. Pero si queres tener un detalle, aca te dejo mis datos.",
                "showButton": true,
                "button": { "text": "Ver datos", "url": "#", "variant": "secondary", "action": "modal" },
                "modalMode": "combined",
                "modals": [
                    {
                        "type": "bank",
                        "title": "Datos de transferencia",
                        "description": "Muchas gracias!",
                        "bankData": [
                            { "label": "Alias", "value": "MI.ALIAS" },
                            { "label": "CBU", "value": "0000000000000000000000" }
                        ]
                    },
                    {
                        "type": "address",
                        "title": "Regalos fisicos",
                        "subtitle": "Mi direccion",
                        "address": "Calle Ejemplo 123, Ciudad",
                        "button": { "text": "Como llegar", "url": "https://maps.google.com/?q=..." }
                    }
                ]
            }
        },

        {
            "_comment": "EMOTIONAL QUOTE: Frase emotiva centrada.",
            "type": "emotionalQuote",
            "id": "emotional-quote",
            "enabled": true,
            "bgColor": "primary",
            "blocks": ["text"],
            "data": { "text": "Creciendo, sonando, brillando." }
        },

        {
            "_comment": "TRIVIA: Juego de preguntas multiples en modal.",
            "type": "trivia",
            "id": "trivia-game-modal",
            "enabled": true,
            "blocks": ["title", "subtitle", "button", "modal"],
            "data": {
                "title": "Cuanto me conoces?",
                "subtitle": "Jugamos?",
                "button": { "text": "Iniciar Trivia", "variant": "primary" },
                "modal": {
                    "finishTitle": "Eso es todo!",
                    "finishText": "Gracias por jugar.",
                    "questions": [
                        { "question": "Cual es mi comida favorita?", "options": ["Pizza", "Sushi", "Asado", "Pasta"], "correctIndex": 2, "explanation": "Asado siempre!" }
                    ]
                }
            }
        },

        {
            "_comment": "PLAYLIST: Link a playlist de Spotify.",
            "type": "playlist",
            "id": "playlist-suggestion",
            "enabled": true,
            "blocks": ["title", "description", "button"],
            "data": {
                "title": "Arma la playlist",
                "description": "Agrega tus canciones favoritas a la playlist de mi fiesta.",
                "button": { "text": "Ir a la playlist", "url": "https://open.spotify.com", "variant": "primary" }
            }
        },

        {
            "_comment": "RSVP: Formulario de confirmacion. Al confirmar, envia datos por WhatsApp. messageTemplate usa {resumen} como placeholder.",
            "type": "rsvp",
            "id": "rsvp-form",
            "enabled": true,
            "bgColor": "primary",
            "blocks": ["title", "form"],
            "data": {
                "title": "Confirma tu asistencia",
                "deadline": "Antes del 1 de septiembre",
                "guestCountLabel": "Numero de personas",
                "guestCountOptions": [1, 2, 3, 4, 5],
                "fields": {
                    "firstName": "Nombre",
                    "lastName": "Apellido",
                    "attendance": "Confirmas tu asistencia?",
                    "attendanceYes": "Confirmo!",
                    "attendanceNo": "No podre asistir",
                    "dietary": "Requerimiento alimentario?",
                    "dietaryOptions": ["Ninguno", "Vegetariano", "Vegano", "Celiaco", "Otro"],
                    "songRequest": "Que cancion no puede faltar?",
                    "submitButton": "Confirmar"
                },
                "whatsapp": {
                    "number": "NUMERO_WHATSAPP_SIN_MAS",
                    "messageTemplate": "Hola! Confirmo asistencia para los 15 de NOMBRE:\n{resumen}\nGracias!"
                }
            }
        },

        {
            "_comment": "CONFIRMAR WHATSAPP: Confirmacion simple. subtitle: (opcional) texto entre titulo y boton.",
            "type": "confirmarWhatsapp",
            "id": "confirmar-whatsapp",
            "enabled": true,
            "bgColor": "primary",
            "blocks": ["title", "subtitle", "button"],
            "data": {
                "title": "Confirmar asistencia",
