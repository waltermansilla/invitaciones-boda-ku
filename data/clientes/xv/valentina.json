            "data": {
                "title": "Mi Historia",
                "aspectRatio": "3/4",
                "moments": [
                    {
                        "image": "/clientes/xv/valentina/images/story-1.jpg",
                        "title": "Mis primeros pasos",
                        "text": "Desde chiquita siempre fui curiosa. Tocaba todo, preguntaba todo y no paraba quieta ni un segundo. Mama dice que aprender a caminar fue solo el principio del caos."
                    },
                    {
                        "image": "/clientes/xv/valentina/images/story-2.jpg",
                        "title": "La del medio",
                        "text": "El colegio, las amigas, las pijamadas, los primeros bailes frente al espejo. Ahi empece a descubrir quien quiero ser y de que cosas me quiero rodear."
                    },
                    {
                        "image": "/clientes/xv/valentina/images/story-3.jpg",
                        "title": "Hoy, mis 15",
                        "text": "Y aca estoy. Con 15 anos, un millon de suenos y la certeza de que todo lo lindo esta por venir. Esta noche celebro con las personas que me hicieron ser quien soy."
                    }
                ]
            }
        },

