    "//": "",
    "// NO se usa en la app. Solo de referencia.",
    "// Para crear una nueva boda: copiar a data/clientes/boda/[slug].json",
    "// y borrar/editar lo que no necesites.",

    "meta": {
        "title": "Boda - Nombre & Nombre",
        "description": "Te invitamos a celebrar nuestra boda.",
        "lang": "es",
        "coupleNames": {
            "groomName": "Nombre del novio",
            "brideName": "Nombre de la novia",
            "separator": "&"
        }
    },

    "theme": {
        "primaryColor": "#6B7F5E",
        "backgroundColor": "#FAF8F5",
        "textColor": "#3A3A3A",
        "lightBgTextColor": "#4A5A3F",
        "darkBgTextColor": "#FFFFFF",
        "accentBackground": "#EDF2E8",
        "modalTextColor": "#FFFFFF",
        "font": {
            "family": "Playfair Display",
            "weights": "300,400,500,600,700"
        }
    },

    "overlay": {
        "enabled": true,
        "phrase": "Nos casamos!",
        "buttonText": "Abrir invitacion"
    },

    "music": {
        "enabled": true,
        "src": "/music/background.mp3",
        "autoplay": false
    },

    "hero": {
        "coupleImage": "/clientes/boda/[slug]/hero.jpg",
        "headline": "Nos casamos!",
        "showNamesOnPhoto": true,

        "_comment_namesDisplay": "NOMBRES EN LA FOTO. enabled: true/false. position: 'top'/'bottom'. color: hex (compartido). decorativeLines: lineas decorativas. logo: ruta imagen (reemplaza textos). TEXTOS SEPARADOS: usar 'texts' array con 2 items, cada uno con text/font/weight/size/style propios.",
        "namesDisplay": {
            "enabled": true,
            "position": "bottom",
            "color": "rgba(255,255,255,0.9)",
            "decorativeLines": false,
            "logo": "",
            "_comment_texts": "OPCIONAL: Para 2 textos con estilos distintos. Si no usas esto, usa font/weight/size/style afuera para ambos nombres.",
            "texts": [
                { "text": "María", "font": "", "weight": "300", "size": "xl", "style": "normal" },
                { "text": "Juan", "font": "", "weight": "300", "size": "xl", "style": "normal" }
            ],
            "_comment_legacy": "Si no usas 'texts', estos valores se aplican a ambos nombres (toma brideName y groomName de meta):",
            "font": "",
            "weight": "300",
            "size": "lg",
            "style": "normal"
        },

        "countdownPrefix": "Faltan",
        "eventDate": "2027-01-01T21:00:00",
        "countdownLabels": {
            "days": "Dias",
            "hours": "Horas",
            "minutes": "Minutos",
            "seconds": "Segundos"
        },

        "_comment_countdownAreaBg": "FONDO DEL AREA DEL COUNTDOWN (donde esta headline + contador). Opciones: 'background' (claro), 'primary' (color principal), o un hex como '#F5E6D3'.",
        "countdownAreaBg": "background",

        "_comment_countdownStyle": "ESTILO DE CADA NUMERO. background: 'none'/'background'/'primary'/'secondary' o hex. shape: 'rounded'/'circle'/'square'/'pill' (circle ahora con tamaños iguales). layout: 'inline' (normal debajo del hero) o 'overlay' (superpuesto en la transicion entre hero y siguiente seccion, sin headline).",
        "countdownStyle": {
            "background": "none",
            "shape": "rounded",
            "layout": "inline"
        }
    },

    "_comment_sections": "El orden de los objetos define el orden visual en la pagina. enabled: true/false para activar/desactivar cada seccion (true por defecto). bgColor: 'primary' = fondo color principal, 'background' = fondo claro (default si no se pone).",

    "sections": [

        {
            "_comment": "QUOTE: Frase de bienvenida. decorativeLines: true/false para lineas arriba y abajo.",
            "type": "quote",
            "id": "quote-welcome",
            "enabled": true,
            "bgColor": "primary",
            "blocks": ["text", "author"],
            "data": {
                "text": "El amor no se mira, se siente, y aun mas cuando ella esta junto a mi.",
                "author": "Julio Cortazar",
                "decorativeLines": true
            }
        },

        {
            "_comment": "OUR STORY: Momentos importantes de la pareja con fotos.",
            "type": "ourStory",
            "id": "our-story",
            "enabled": true,
            "bgColor": "background",
            "blocks": ["title", "moments"],
            "data": {
                "aspectRatio": "3/4",
                "title": "Nuestra historia",
                "moments": [
                    {
                        "image": "/clientes/boda/[slug]/momento-1.jpg",
                        "title": "Como nos conocimos",
                        "text": "Descripcion del momento."
                    },
                    {
                        "image": "/clientes/boda/[slug]/momento-2.jpg",
                        "title": "Primera cita",
                        "text": "Descripcion del momento."
                    },
                    {
                        "image": "/clientes/boda/[slug]/momento-3.jpg",
                        "title": "La propuesta",
                        "text": "Descripcion del momento."
                    }
                ]
            }
        },

