{
    "// ==========================================": "",
    "// TEMPLATE BODA - TODAS LAS SECCIONES      ": "",
    "// ==========================================.": "",
    "//": "",
    "// NO se usa en la app. Solo de referencia.",
    "// Para crear una nueva boda: copiar a data/clientes/boda/[slug].json",
    "// y borrar/editar lo que no necesites.",

    "meta": {
        "title": "Boda - Nombre & Nombre",
        "description": "Te invitamos a celebrar nuestra boda.",
        "lang": "es",
        "coupleNames": {
            "groomName": "Nombre del novio",
            "brideName": "Nombre de la novia",
            "separator": "&"
        }
    },

    "theme": {
        "primaryColor": "#6B7F5E",
        "backgroundColor": "#FAF8F5",
        "textColor": "#3A3A3A",
        "lightBgTextColor": "#4A5A3F",
        "darkBgTextColor": "#FFFFFF",
        "accentBackground": "#EDF2E8",
        "modalTextColor": "#FFFFFF",
        "font": {
            "family": "Playfair Display",
            "weights": "300,400,500,600,700"
        }
    },

    "overlay": {
        "enabled": true,
        "phrase": "Nos casamos!",
        "buttonText": "Abrir invitacion"
    },

    "music": {
        "enabled": true,
        "src": "/music/background.mp3",
        "autoplay": false
    },

    "hero": {
        "coupleImage": "/clientes/boda/[slug]/hero.jpg",
        "headline": "Nos casamos!",
        "showNamesOnPhoto": true,
        "countdownPrefix": "Faltan",
        "eventDate": "2027-01-01T21:00:00",
        "countdownLabels": {
            "days": "Dias",
            "hours": "Horas",
            "minutes": "Minutos",
            "seconds": "Segundos"
        }
    },

    "_comment_sections": "El orden de los objetos define el orden visual en la pagina. bgColor: 'primary' = fondo color principal, 'background' = fondo claro (default si no se pone).",

    "sections": [

        {
            "_comment": "QUOTE: Frase de bienvenida. decorativeLines: true/false para lineas arriba y abajo.",
            "type": "quote",
            "id": "quote-welcome",
            "bgColor": "primary",
            "blocks": ["text", "author"],
            "data": {
                "text": "El amor no se mira, se siente, y aun mas cuando ella esta junto a mi.",
                "author": "Julio Cortazar",
                "decorativeLines": true
            }
        },

        {
            "_comment": "OUR STORY: Momentos importantes de la pareja con fotos.",
            "type": "ourStory",
            "id": "our-story",
            "bgColor": "background",
            "blocks": ["title", "moments"],
            "data": {
                "aspectRatio": "3/4",
                "title": "Nuestra historia",
                "moments": [
                    {
                        "image": "/clientes/boda/[slug]/momento-1.jpg",
                        "title": "Como nos conocimos",
                        "text": "Descripcion del momento."
                    },
                    {
                        "image": "/clientes/boda/[slug]/momento-2.jpg",
                        "title": "Primera cita",
                        "text": "Descripcion del momento."
                    },
                    {
                        "image": "/clientes/boda/[slug]/momento-3.jpg",
                        "title": "La propuesta",
                        "text": "Descripcion del momento."
                    }
                ]
            }
        },

        {
            "_comment": "DATE INFO: Fecha del evento.",
            "type": "dateInfo",
            "id": "date-info",
            "bgColor": "background",
            "blocks": ["title", "value"],
            "data": {
                "title": "Cuando?",
                "value": "17 de Febrero 2027"
            }
        },

        {
            "_comment": "LOCATION INFO: Ubicacion con boton de mapa. Duplicar con distinto id para varias ubicaciones.",
            "type": "locationInfo",
            "id": "location-civil",
            "bgColor": "background",
            "blocks": ["title", "address", "button"],
            "data": {
                "title": "Civil",
                "address": "Registro Civil - Direccion completa",
                "button": {
                    "text": "Como llegar",
                    "url": "https://maps.google.com",
                    "variant": "primary"
                }
            }
        },

        {
            "_comment": "LOCATION INFO: Segunda ubicacion (fiesta).",
            "type": "locationInfo",
            "id": "location-fiesta",
            "bgColor": "background",
            "blocks": ["title", "address", "button"],
            "data": {
                "title": "Fiesta",
                "address": "Salon - Direccion completa",
                "button": {
                    "text": "Como llegar",
                    "url": "https://maps.google.com",
                    "variant": "primary"
                }
            }
        },

        {
            "_comment": "GALLERY: Slider de fotos.",
            "type": "gallery",
            "id": "gallery-photos",
            "blocks": ["slider"],
            "data": {
                "aspectRatio": "3/4",
                "images": [
                    "/clientes/boda/[slug]/galeria-1.jpg",
                    "/clientes/boda/[slug]/galeria-2.jpg",
                    "/clientes/boda/[slug]/galeria-3.jpg"
                ]
            }
        },

        {
            "_comment": "ITINERARY: Linea de tiempo con iconos, fechas opcionales y botones opcionales. ICONOS: heart, wine, utensils, music, church, camera, cake, car, glass, party, sparkles, sun, moon, clock, pin, gift, bus, podium, book, salon, civil, mate, fin, sidra, mesaDulce, tortaCasamiento.",
            "type": "itinerary",
            "id": "itinerary-timeline",
            "bgColor": "background",
            "blocks": ["title", "timeline"],
            "data": {
                "title": "Itinerario",
                "events": [
                    {
                        "icon": "civil",
                        "name": "Civil",
                        "time": "11:00 hs",
                        "date": "Viernes 16/02",
                        "button": {
                            "text": "Como llegar",
                            "url": "https://maps.google.com",
                            "variant": "secondary"
                        }
                    },
                    { "icon": "church", "name": "Ceremonia", "time": "18:00 hs", "date": "Sabado 17/02" },
                    { "icon": "camera", "name": "Fotos", "time": "19:00 hs" },
                    { "icon": "utensils", "name": "Cena", "time": "21:00 hs" },
                    { "icon": "tortaCasamiento", "name": "Torta", "time": "23:00 hs" },
                    { "icon": "music", "name": "Fiesta", "time": "00:00 hs" },
                    { "icon": "fin", "name": "Fin de fiesta", "time": "05:00 hs" }
                ]
            }
        },

        {
            "_comment": "DRESS CODE: Vestimenta con modal de consejos.",
            "type": "dressCode",
            "id": "dress-code",
            "bgColor": "background",
            "blocks": ["title", "subtitle", "button", "modal"],
            "data": {
                "title": "Vestimenta",
                "subtitle": "Elegante Sport",
                "button": { "text": "Ver consejos", "url": "#", "variant": "secondary" },
                "modal": {
                    "title": "Consejos de vestimenta",
                    "sections": [
                        { "heading": "Hombres", "text": "Descripcion para hombres." },
                        { "heading": "Mujeres", "text": "Descripcion para mujeres." },
                        { "heading": "General", "text": "Se ruega no vestir de blanco." }
                    ]
                }
            }
        },

        {
            "_comment": "PHOTOS: Invitar a subir fotos al album compartido.",
            "type": "photos",
            "id": "shared-photos",
            "bgColor": "primary",
            "blocks": ["icon", "title", "description", "button"],
            "data": {
                "title": "Subi tus fotos",
                "description": "Comparti los momentos de la fiesta!",
                "button": { "text": "Ir al album", "url": "https://photos.google.com", "variant": "background" }
            }
        },

        {
            "_comment": "TRUTHS: Juego A o B sobre la pareja.",
            "type": "truths",
            "id": "truths-game",
            "bgColor": "primary",
            "blocks": ["title", "questions"],
            "data": {
                "title": "Pequenas verdades",
                "finishText": "Nos conoces mejor de lo que pensabas!",
                "questions": [
                    {
                        "question": "Quien dijo 'te amo' primero?",
                        "optionA": "Ella",
                        "optionB": "El",
                        "correctOption": "A",
                        "revealText": "Ella se animo primero."
                    }
                ]
            }
        },

        {
            "_comment": "GIFT CARD: Tarjeta de regalo con modal. ICONOS: gift (caja regalo), creditCard (tarjeta), heart (corazon), star (estrella), sparkles (brillos), handHeart (mano corazon), dollar (signo pesos). suggestedValue = valor sugerido (dejar '' si no queres mostrar).",
            "type": "giftCard",
            "id": "gift-card",
            "bgColor": "primary",
            "blocks": ["icon", "title", "description", "button", "modal"],
            "data": {
                "icon": "gift",
                "title": "Valor Tarjeta",
                "description": "Si queres hacernos un regalo, podes contribuir con un valor para nuestra nueva vida juntos.",
                "button": { "text": "Ver datos", "url": "#", "variant": "secondary" },
                "modal": {
                    "title": "Datos de transferencia",
                    "suggestedValue": "$20.000",
                    "description": "Podes transferir el monto que quieras.",
                    "transferData": [
                        { "label": "Alias", "value": "MI.ALIAS" },
                        { "label": "CBU", "value": "0000000000000000000000" },
                        { "label": "Titular", "value": "Nombre Completo" },
                        { "label": "Banco", "value": "Nombre del Banco" }
                    ]
                }
            }
        },

        {
            "_comment": "HONEYMOON: Luna de miel. NO tiene valor sugerido. ICONOS: plane (avion), gift (caja), heart (corazon), star (estrella), sparkles (brillos), moon (luna), handHeart (mano corazon). Usa bankData (no transferData).",
            "type": "honeymoon",
            "id": "honeymoon",
            "bgColor": "primary",
            "blocks": ["icon", "title", "description", "button", "modal"],
            "data": {
                "icon": "plane",
                "title": "Luna de miel",
                "description": "Si queres ayudarnos con nuestra luna de miel, te dejamos los datos.",
                "button": { "text": "Ver datos", "url": "#", "variant": "secondary" },
                "modal": {
                    "title": "Datos para la luna de miel",
                    "description": "Cualquier aporte nos ayuda a cumplir nuestro sueno.",
                    "bankData": [
                        { "label": "Alias", "value": "LUNA.DE.MIEL" },
                        { "label": "CBU", "value": "0000000000000000000000" },
                        { "label": "Titular", "value": "Nombre Completo" },
                        { "label": "Banco", "value": "Nombre del Banco" }
                    ],
                    "thankYouText": "Gracias por ayudarnos a cumplir nuestro sueno!"
                }
            }
        },

        {
            "_comment": "EMOTIONAL QUOTE: Frase emotiva centrada.",
            "type": "emotionalQuote",
            "id": "emotional-quote",
            "bgColor": "primary",
            "blocks": ["text"],
            "data": { "text": "Lo mejor de la vida es compartirla con alguien especial." }
        },

        {
            "_comment": "TRIVIA: Juego de preguntas con opciones multiples en modal.",
            "type": "trivia",
            "id": "trivia-game",
            "blocks": ["title", "subtitle", "button", "modal"],
            "data": {
                "title": "Cuanto nos conoces?",
                "subtitle": "Jugamos?",
                "button": { "text": "Iniciar Trivia", "variant": "primary" },
                "modal": {
                    "finishTitle": "Eso es todo!",
                    "finishText": "Gracias por jugar.",
                    "questions": [
                        {
                            "question": "Donde fue nuestra primera cita?",
                            "options": ["Un bar", "El cine", "La playa", "Un parque"],
                            "correctIndex": 0,
                            "explanation": "Fue en un bar del centro!"
                        }
                    ]
                }
            }
        },

        {
            "_comment": "PLAYLIST: Link a playlist de Spotify.",
            "type": "playlist",
            "id": "playlist-suggestion",
            "blocks": ["title", "description", "button"],
            "data": {
                "title": "Arma la playlist",
                "description": "Agrega tus canciones favoritas a la playlist de la fiesta.",
                "button": { "text": "Ir a la playlist", "url": "https://open.spotify.com", "variant": "primary" }
            }
        },

        {
            "_comment": "RSVP: Formulario de confirmacion. Al confirmar, envia datos por WhatsApp. messageTemplate usa {resumen} como placeholder para los datos de los invitados.",
            "type": "rsvp",
            "id": "rsvp-form",
            "bgColor": "primary",
            "blocks": ["title", "form"],
            "data": {
                "title": "Confirma tu asistencia",
                "deadline": "Antes del 1 de septiembre",
                "guestCountLabel": "Numero de personas",
                "guestCountOptions": [1, 2, 3, 4, 5],
                "fields": {
                    "firstName": "Nombre",
                    "lastName": "Apellido",
                    "attendance": "Confirmas tu asistencia?",
                    "attendanceYes": "Confirmo!",
                    "attendanceNo": "No podre asistir",
                    "dietary": "Requerimiento alimentario?",
                    "dietaryOptions": ["Ninguno", "Vegetariano", "Vegano", "Celiaco", "Otro"],
                    "songRequest": "Que cancion no puede faltar?",
                    "submitButton": "Confirmar"
                },
                "whatsapp": {
                    "number": "NUMERO_WHATSAPP_SIN_MAS",
                    "messageTemplate": "Hola! Confirmo asistencia para la boda de NOMBRE & NOMBRE:\n{resumen}\nGracias!"
                }
            }
        },

        {
            "_comment": "CONFIRMAR WHATSAPP: Confirmacion simple por WhatsApp (PLAN BASE, sin formulario). Boton que abre WhatsApp directo con mensaje predefinido. NO incluir en plan Premium (usar rsvp en su lugar).",
            "type": "confirmarWhatsapp",
            "id": "confirmar-whatsapp",
            "bgColor": "primary",
            "blocks": ["title", "button"],
            "data": {
                "title": "Confirmar asistencia",
                "buttonText": "Confirmar por WhatsApp",
                "whatsappNumber": "NUMERO_WHATSAPP_SIN_MAS",
                "message": "Confirmo mi asistencia a la boda de NOMBRE & NOMBRE"
            }
        },

        {
            "_comment": "SPECIAL MESSAGE: Mensaje personal de los novios. decorativeLines: true/false para lineas arriba y abajo.",
            "type": "specialMessage",
            "id": "special-message",
            "blocks": ["title", "text"],
            "data": {
                "title": "Gracias por acompanarnos",
                "text": "Mensaje personal de los novios para los invitados.",
                "signature": "Nombre & Nombre",
                "decorativeLines": true
            }
        },

        {
            "_comment": "CLOSING IMAGE: Foto de cierre con nombres superpuestos.",
            "type": "closingImage",
            "id": "closing-image",
            "blocks": ["image", "coupleNames"],
            "data": { "aspectRatio": "3/4", "image": "/clientes/boda/[slug]/cierre.jpg" }
        },

        {
            "_comment": "FOOTER: Pie de pagina con redes de TU MARCA (no del cliente).",
            "type": "footer",
            "id": "footer-credits",
            "blocks": ["socialLinks", "brandName"],
            "data": {
                "brandName": "walter invitaciones",
                "socialLinks": [
                    { "icon": "instagram", "url": "https://instagram.com/tu_marca" },
