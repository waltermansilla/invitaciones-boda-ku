            "blocks": ["title", "value"],
            "data": {
                "title": "Cuando?",
                "value": "17 de Febrero 2027"
            }
        },

        {
            "_comment": "LOCATION INFO: Ubicacion con boton de mapa. ICONOS: 'pin' (default), 'church', 'dinner', 'party', 'salon', 'book', 'podium', 'reception', 'ring', 'music', 'sparkles'. showButton: true/false. datetime: fecha y hora opcional.",
