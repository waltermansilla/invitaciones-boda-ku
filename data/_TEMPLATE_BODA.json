        {
            "_comment": "DRESS CODE: Vestimenta con iconos, colores y modal opcional. ICONOS: dress (vestido), suit (traje), gem (diamante), crown (corona), sparkles (brillos), star (estrella), heart (corazon). showButton: true/false para mostrar/ocultar boton. colorSwatches: enabled (true/false), shape ('circle' o 'square'), colors (array de hex).",
            "type": "dressCode",
            "id": "dress-code",
            "enabled": true,
            "bgColor": "background",
            "blocks": ["title", "subtitle", "icons", "description", "colorSwatches", "button", "modal"],
            "data": {
                "icons": ["dress", "suit", "gem"],
                "title": "Vestimenta",
                "subtitle": "Elegante Sport",
                "description": "El blanco esta reservado para la novia",
                "showButton": true,
                "colorSwatches": {
                    "enabled": true,
                    "shape": "circle",
                    "colors": ["#2C3E50", "#8E44AD", "#1ABC9C", "#E74C3C"]
                },
                "button": { "text": "Ver consejos", "url": "#", "variant": "secondary" },
                "modal": {
                    "title": "Consejos de vestimenta",
                    "sections": [
                        { "heading": "Hombres", "text": "Descripcion para hombres." },
                        { "heading": "Mujeres", "text": "Descripcion para mujeres." },
                        { "heading": "General", "text": "Se ruega no vestir de blanco." }
                    ]
                }
            }
        },

        {
            "_comment": "PHOTOS: Invitar a subir fotos al album compartido. ICONOS: 'camera' (camara), 'flash' (flash), 'images' (fotos). Dejar vacio para sin icono.",
