                "_comment_action": "action: 'modal' abre modal, 'url' abre el link directo en button.url",
                "modalMode": "combined",
                "_comment_modalMode": "combined = ambos modales juntos. sequential = primero uno, boton para ir al otro.",
                "modals": [
